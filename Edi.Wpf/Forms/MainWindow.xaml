<Window x:Class="Edi.Forms.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Edi.Forms"
        mc:Ignorable="d"
        Title="Edi Launcher" Height="550" Width="850" ResizeMode="CanResize">

    <Window.Resources>
        <local:BoolToReadyIconConverter x:Key="BoolToReadyIconConverter"/>
    </Window.Resources>


    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Column: Settings and Controls -->
        <StackPanel Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Margin="0,0,10,0">
            <!-- Game Selection Group -->
            <GroupBox Header="Game &amp; General" Margin="0,0,0,10" Padding="5">
                <StackPanel>
                    <DockPanel Margin="0,0,0,5">
                        <Label Content="Game:" VerticalAlignment="Center" Width="60"/>
                        <Button Content="Select..." DockPanel.Dock="Right" Width="60" Margin="5,0,0,0" Click="ReloadButton_Click" ToolTip="Select EdiConfig.json or Definition.csv"/>
                        <ComboBox x:Name="GamesComboBox"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Path"
                                  ItemsSource="{Binding gamesConfig.GamesInfo}"
                                  SelectedItem="{Binding gamesConfig.SelectedGameinfo, Mode=TwoWay}"
                                  SelectionChanged="GamesComboBox_SelectionChanged"
                                  ToolTip="Choose the game to integrate with"/>
                    </DockPanel>
                    <DockPanel Margin="0,0,0,5">
                        <Label Content="Intensity:" VerticalAlignment="Center" Width="60"/>
                        <Label Content="{Binding ElementName=sliderIntensity, Path=Value}" DockPanel.Dock="Right" Width="30" HorizontalContentAlignment="Right"/>
                        <Slider x:Name="sliderIntensity" Value="100" Maximum="100" ValueChanged="Slider_ValueChanged" VerticalAlignment="Center" ToolTip="Global vibration/motion intensity"/>
                    </DockPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                        <CheckBox Content="Filler" Margin="5,0" IsChecked="{Binding config.Filler, Mode=TwoWay}" ToolTip="Enable passive background motions"/>
                        <CheckBox Content="Gallery" Margin="5,0" IsChecked="{Binding config.Gallery, Mode=TwoWay}" ToolTip="Enable primary scene playback"/>
                        <CheckBox Content="Reaction" Margin="5,0" IsChecked="{Binding config.Reactive, Mode=TwoWay}" ToolTip="Enable short event responses"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- Device Connection Group -->
            <GroupBox Header="Connection Settings" Margin="0,0,0,10" Padding="5">
                <StackPanel>
                    <DockPanel Margin="0,2">
                        <Label Content="Handy Key:" Width="85" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding handyConfig.Key}" ToolTip="Your Handy or AutoBlow connection key"/>
                    </DockPanel>
                    <DockPanel Margin="0,2">
                        <Label Content="Intiface URL:" Width="85" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding buttplugConfig.Url}" ToolTip="Buttplug/Intiface Desktop server address"/>
                    </DockPanel>
                    <DockPanel Margin="0,2">
                        <Label Content="E-Stim Device:" Width="85" VerticalAlignment="Center"/>
                        <ComboBox Name="audioDevicesComboBox" 
                                  DisplayMemberPath="name" 
                                  SelectedValuePath="id" 
                                  SelectedValue="{Binding estimConfig.DeviceId}" 
                                  ToolTip="Audio device for E-Stim (requires MP3 funscripts)"/>
                    </DockPanel>
                    <DockPanel Margin="0,2">
                        <Label Content="OSR COM:" Width="85" VerticalAlignment="Center"/>
                        <ComboBox Name="comPortsComboBox" 
                                  DisplayMemberPath="name" 
                                  SelectedValuePath="value" 
                                  SelectedValue="{Binding osrConfig.COMPort}" 
                                  ToolTip="Serial port for OSR-TCode devices"/>
                    </DockPanel>
                    <DockPanel Margin="0,2">
                        <Label Content="OSR UDP:" Width="85" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding osrConfig.UdpAddress}" ToolTip="UDP Address for OSR (e.g., 127.0.0.1:1234)"/>
                    </DockPanel>
                    <Button Content="Reconnect Devices" Margin="0,10,0,0" Height="25" x:Name="ReconnectButton" Click="ReconnectButton_ClickAsync" ToolTip="Refresh connections for all enabled devices"/>
                </StackPanel>
            </GroupBox>

            <!-- Manual Playback Group -->
            <GroupBox Header="Playback Control" Padding="5">
                <StackPanel>
                    <DockPanel Margin="0,0,0,10">
                        <Label Content="Gallery:" VerticalAlignment="Center" Width="60"/>
                        <ComboBox x:Name="cmbGallerie" DisplayMemberPath="Name" ItemsSource="{Binding galleries}" ToolTip="Select a gallery to play manually"/>
                    </DockPanel>
                    <UniformGrid Columns="5" Height="30">
                        <Button x:Name="btnPlay" Click="btnPlay_Click" ToolTip="Play selected gallery">
                            <TextBlock Text="▶" FontSize="16"/>
                        </Button>
                        <Button x:Name="btnStop" Click="btnStop_Click" ToolTip="Stop playback">
                            <TextBlock Text="■" FontSize="16"/>
                        </Button>
                        <Button x:Name="btnPause" Click="btnPause_Click" ToolTip="Pause playback">
                            <TextBlock Text="❚❚" FontSize="14"/>
                        </Button>
                        <Button x:Name="btnResume" Click="btnResume_Click" ToolTip="Resume playback">
                            <TextBlock Text="►❚❚" FontSize="14"/>
                        </Button>
                        <Button x:Name="btnSimulator" Click="btnSimulator_Click" ToolTip="Toggle Visualizer Window">
                            <TextBlock Text="👁️" FontSize="16"/>
                        </Button>
                    </UniformGrid>
                </StackPanel>
            </GroupBox>
        </StackPanel>

        <!-- Right Column: Active Devices and Logs -->
        <GroupBox Header="Active Devices" Grid.Column="1" Grid.Row="0" Grid.RowSpan="2" Padding="5">
            <DataGrid x:Name="DevicesGrid" ItemsSource="{Binding devices}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Device Name" Binding="{Binding Name}" Width="*"/>
                    <DataGridTemplateColumn Header="Variant" Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding Variants}" SelectionChanged="Variants_SelectionChanged" SelectedItem="{Binding SelectedVariant, Mode=TwoWay}" Width="100"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Ready" Binding="{Binding IsReady, Converter={StaticResource BoolToReadyIconConverter}, Mode=OneWay}" Width="Auto">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="FontFamily" Value="Segoe UI Emoji"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="Channel" x:Name="ChannelColumn" Visibility="Collapsed">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.channels, RelativeSource={RelativeSource AncestorType=Window}}"
                                          SelectionChanged="Channels_SelectionChanged"
                                          SelectedValue="{Binding Channel, Mode=TwoWay}" Width="80"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <!-- Footer: Status and Tools -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" BorderBrush="#DDD" BorderThickness="0,1,0,0" Margin="0,10,0,0" Padding="5,5,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Label Content="Status:" FontWeight="Bold"/>
                    <Label x:Name="lblStatus" Content="Ready"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Label Foreground="Blue" Content="API Documentation (Swagger)" Cursor="Hand" MouseDoubleClick="Label_MouseDoubleClick" ToolTip="Double-click to open API documentation in browser" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <Button Content="🛠" Width="25" x:Name="btnOpenOutput" Click="btnOpenOutput_Click" ToolTip="Open configuration/log directory"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

